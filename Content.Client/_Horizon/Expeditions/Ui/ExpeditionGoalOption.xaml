<PanelContainer xmlns="https://spacestation14.io"
                xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                HorizontalExpand="True"
                VerticalExpand="True"
                StyleClasses="PdaBorderRect"
                Name="BigPanel"
                Margin="4">
    <BoxContainer Orientation="Vertical"
                  VerticalExpand="True"
                  Margin="5 5">
        <!-- Title box -->
        <controls:StripeBack>
            <Label Name="TitleStripe"
                   HorizontalAlignment="Center"
                   Margin="0 5 0 5"/>
        </controls:StripeBack>
        <SpriteView Name="Icon"
                    Scale="6 6"
                    Access="Public"
                    Margin="0"
                    HorizontalAlignment="Center"/>
        <ScrollContainer HorizontalExpand="True"
                         VerticalExpand="True"
                         MinHeight="92"
                         Margin="4">
            <RichTextLabel Name="DescriptionLabel"
                       HorizontalExpand="True"
                       Margin="4"/>
        </ScrollContainer>
        <BoxContainer Orientation="Vertical" VerticalExpand="True" VerticalAlignment="Bottom" Name="ContentBox">
            <RichTextLabel Name="RewardLabel"
                           HorizontalExpand="True"
                           Margin="4"/>
        </BoxContainer>
        <Button Name="ClaimButton"
                HorizontalExpand="True"
                VerticalAlignment="Bottom"
                Access="Public"
                Text="{Loc 'offering-window-claim'}"/>
    </BoxContainer>
</PanelContainer>
