<PanelContainer
    xmlns="https://spacestation14.io"
    xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    HorizontalExpand="True"
    Margin="0 2">
    <!-- Card background -->
    <PanelContainer Name="CardBackground" HorizontalExpand="True" VerticalExpand="True">
        <PanelContainer.PanelOverride>
            <gfx:StyleBoxFlat BackgroundColor="#1a2a3a60" BorderColor="#3a5a7a80" BorderThickness="1" ContentMarginLeftOverride="8" ContentMarginRightOverride="8" ContentMarginTopOverride="6" ContentMarginBottomOverride="6" />
        </PanelContainer.PanelOverride>

        <BoxContainer Orientation="Horizontal" SeparationOverride="10" HorizontalExpand="True">

            <!-- Item icon with background -->
            <PanelContainer MinSize="48 48" MaxSize="48 48" VerticalAlignment="Center">
                <PanelContainer.PanelOverride>
                    <gfx:StyleBoxFlat BackgroundColor="#ffffff10" BorderColor="#ffffff18" BorderThickness="1" />
                </PanelContainer.PanelOverride>
                <TextureRect Name="ItemIcon" MinSize="40 40" Stretch="KeepAspectCentered" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4" />
            </PanelContainer>

            <!-- Item info -->
            <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalAlignment="Center" SeparationOverride="2">
                <Label Name="ItemNameLabel" StyleClasses="LabelHeading" />
                <Label Name="ItemDescLabel" StyleClasses="LabelSubText" ClipText="True" />
                <BoxContainer Orientation="Horizontal" SeparationOverride="12">
                    <Label Name="ItemCostLabel" StyleClasses="LabelSubText" />
                    <Label Name="ItemUsesLabel" StyleClasses="LabelSubText" />
                    <Label Name="ItemGrantedByLabel" StyleClasses="LabelSubText" />
                </BoxContainer>
            </BoxContainer>

            <!-- Toggle button -->
            <Button Name="ToggleButton" ToggleMode="True" MinSize="100 36" VerticalAlignment="Center" />

        </BoxContainer>
    </PanelContainer>
</PanelContainer>
