ent-WeaponShotgun39 = XM1014
    .desc = Боевой дробовик Earth Armories XM1014 — это полуавтоматический дробовик, используемый штурмовиками и передовыми бойцами в составе отрядов Армии Земли. Использует патроны калибра .50.
    .suffix = Backman, Дробовик
ent-WeaponShotgun39NonLethal = XM1014
    .suffix = Backman, Дробовик [Non Lethal]
    .desc = { ent-WeaponShotgun39.desc }
